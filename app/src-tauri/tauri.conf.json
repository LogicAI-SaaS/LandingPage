{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LogicAI",
  "version": "1.0.0",
  "identifier": "com.logicai.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LogicAI Desktop",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3000 ws://localhost:3000 https://api.logicai.fr; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "LogicAI",
    "copyright": "Copyright © 2025 LogicAI",
    "category": "Productivity",
    "shortDescription": "LogicAI Automation Platform",
    "longDescription": "LogicAI Desktop - Deploy and manage your automation workflows locally with Docker integration."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
