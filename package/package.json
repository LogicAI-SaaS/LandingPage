{
  "name": "logicai-sdk",
  "version": "1.0.0",
  "description": "SDK JavaScript/TypeScript pour interagir avec l'API LogicAI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node test-sdk.js",
    "test:form": "ts-node examples/form-submission.ts",
    "test:express": "ts-node examples/express-server.ts",
    "test:monitor": "ts-node examples/monitoring.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "logicai",
    "workflow",
    "automation",
    "sdk",
    "api-client"
  ],
  "author": "LogicAI",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/logicai.git"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
